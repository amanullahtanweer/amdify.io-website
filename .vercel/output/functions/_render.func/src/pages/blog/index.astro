---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

const DATA_FILE = path.join(process.cwd(), 'src/data/posts.json');
const allPosts = fs.existsSync(DATA_FILE)
  ? JSON.parse(fs.readFileSync(DATA_FILE, 'utf-8'))
  : [];

const featured = allPosts.find((p: any) => p.featured);
const rest = allPosts.filter((p: any) => !p.featured);

const categoryColors: Record<string, string> = {
  Industry:   'bg-rose-500/10 text-rose-400 border-rose-500/20',
  Technology: 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
  Guides:     'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
};
const categoryStripe: Record<string, string> = {
  Industry:   'from-rose-600/50 to-rose-400/30',
  Technology: 'from-indigo-600/50 to-indigo-400/30',
  Guides:     'from-emerald-600/50 to-emerald-400/30',
};
---

<Layout
  title="Blog — AMD Insights for Contact Centers | amdify.io"
  description="Expert guides on answering machine detection, outbound calling strategy, and contact center AI. Written by the amdify.io team."
>
  <!-- NAVBAR -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <img src="/logo.svg" alt="amdify.io" class="h-9 w-9 invert" />
        <span class="text-xl font-bold tracking-tight text-white">amdify<span class="text-indigo-400">.io</span></span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/#features" class="text-sm text-neutral-400 hover:text-white transition-colors">Features</a>
        <a href="/#how-it-works" class="text-sm text-neutral-400 hover:text-white transition-colors">How It Works</a>
        <a href="/#pricing" class="text-sm text-neutral-400 hover:text-white transition-colors">Pricing</a>
        <a href="/blog" class="text-sm text-white font-medium relative">
          Blog
          <span class="absolute -bottom-1 left-0 right-0 h-px bg-indigo-400 rounded-full"></span>
        </a>
        <a href="/#faq" class="text-sm text-neutral-400 hover:text-white transition-colors">FAQ</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="https://monitor.amdify.io" class="hidden sm:inline-flex text-sm text-neutral-300 hover:text-white px-4 py-2">Sign In</a>
        <a href="/#pricing" class="inline-flex items-center gap-2 bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-all hover:shadow-lg hover:shadow-indigo-500/25">
          Get Started
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-neutral-400 hover:text-white p-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-800 bg-neutral-950/95 backdrop-blur-xl">
      <div class="px-6 py-4 flex flex-col gap-3">
        <a href="/#features" class="text-sm text-neutral-400 hover:text-white py-2">Features</a>
        <a href="/#how-it-works" class="text-sm text-neutral-400 hover:text-white py-2">How It Works</a>
        <a href="/#pricing" class="text-sm text-neutral-400 hover:text-white py-2">Pricing</a>
        <a href="/blog" class="text-sm text-white font-medium py-2">Blog</a>
        <a href="/#faq" class="text-sm text-neutral-400 hover:text-white py-2">FAQ</a>
        <a href="https://monitor.amdify.io" class="text-sm text-neutral-400 hover:text-white py-2">Sign In</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative pt-40 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-indigo-500/6 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neutral-800 to-transparent"></div>
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,.015)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.015)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="flex items-center gap-2 text-sm text-neutral-500 mb-8">
        <a href="/" class="hover:text-neutral-300 transition-colors">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-300">Blog</span>
      </div>
      <div class="max-w-2xl">
        <span class="text-sm font-medium text-indigo-400 tracking-wider uppercase mb-4 block">The amdify.io Blog</span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-5">
          Insights for Modern
          <span class="bg-gradient-to-r from-indigo-400 via-indigo-300 to-purple-400 bg-clip-text text-transparent"> Contact Centers</span>
        </h1>
        <p class="text-lg text-neutral-400 leading-relaxed">AMD technology, outbound strategy, and the numbers behind high-performing contact center operations.</p>
      </div>
    </div>
  </section>

  <!-- FEATURED -->
  {featured && (
    <section class="pb-8">
      <div class="max-w-7xl mx-auto px-6">
        <a href={`/blog/${featured.slug}`} class="group relative block bg-neutral-900/50 border border-neutral-800 rounded-2xl overflow-hidden hover:border-indigo-500/30 transition-all duration-300">
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/[0.04] to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative grid lg:grid-cols-2">
            <div class="relative h-56 lg:h-auto min-h-[280px] bg-gradient-to-br from-neutral-900 to-neutral-950 flex items-center justify-center overflow-hidden border-b lg:border-b-0 lg:border-r border-neutral-800">
              {featured.coverImage ? (
                <img src={featured.coverImage} alt={featured.title} class="absolute inset-0 w-full h-full object-cover opacity-40" />
              ) : (
                <>
                  <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,.04)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,.04)_1px,transparent_1px)] bg-[size:32px_32px]"></div>
                  <div class="relative flex items-end gap-1.5 h-24">
                    {[20,45,30,70,50,90,60,80,40,95,55,75,35,85,25,65,45,78,30,60].map((h, i) => (
                      <div
                        class={`rounded-full w-2 waveform-bar ${i%3===0?'bg-gradient-to-t from-rose-500/60 to-rose-400/80':i%3===1?'bg-gradient-to-t from-indigo-500/50 to-indigo-400/70':'bg-gradient-to-t from-neutral-600/40 to-neutral-500/60'}`}
                        style={`height:${h}%;animation-delay:${i*.06}s`}
                      />
                    ))}
                  </div>
                </>
              )}
              <div class="absolute bottom-4 left-4">
                <span class={`inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full border ${categoryColors[featured.category]}`}>
                  <span class="w-1.5 h-1.5 rounded-full bg-current"></span>{featured.category}
                </span>
              </div>
              <div class="absolute top-4 right-4 bg-indigo-500/10 border border-indigo-500/20 rounded-lg px-3 py-1.5">
                <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Featured</span>
              </div>
            </div>
            <div class="p-8 lg:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-5">
<span class="text-xs text-neutral-500 rel-date" data-date={featured.createdAt}>{featured.date}</span>                <span class="text-neutral-700">·</span>
<span class="text-xs text-neutral-500" id="post-date" data-date={featured.createdAt}>{featured.date}</span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4 leading-tight group-hover:text-indigo-100 transition-colors">{featured.title}</h2>
              <p class="text-neutral-400 leading-relaxed mb-8">{featured.excerpt}</p>
              <div class="inline-flex items-center gap-2 text-sm font-medium text-indigo-400 group-hover:gap-3 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- FILTER -->
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-xs text-neutral-500 uppercase tracking-wider font-medium mr-1">Filter:</span>
        {['All','Technology','Industry','Guides'].map(cat => (
          <button
            class={`filter-btn text-xs font-medium px-4 py-2 rounded-lg border transition-all ${cat==='All'?'bg-indigo-500/15 border-indigo-500/30 text-indigo-300':'bg-neutral-900/50 border-neutral-800 text-neutral-400 hover:border-neutral-600 hover:text-neutral-200'}`}
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
        <span class="ml-auto text-xs text-neutral-500 hidden sm:block">{allPosts.length} article{allPosts.length!==1?'s':''}</span>
      </div>
    </div>
  </section>

  <!-- GRID -->
  <section class="pb-24">
    <div class="max-w-7xl mx-auto px-6">
      {allPosts.length === 0 ? (
        <div class="text-center py-28 border border-dashed border-neutral-800 rounded-2xl">
          <div class="w-16 h-16 bg-neutral-900 border border-neutral-800 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <p class="text-white font-medium mb-2">No posts yet</p>
          <p class="text-neutral-500 text-sm">Go to <a href="/admin" class="text-indigo-400 hover:underline">/admin</a> to write your first post.</p>
        </div>
      ) : (
        <div id="posts-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {rest.map((post: any) => (
            <a
              href={`/blog/${post.slug}`}
              class="post-card group relative bg-neutral-900/50 border border-neutral-800 rounded-2xl overflow-hidden hover:border-indigo-500/25 transition-all duration-300 flex flex-col"
              data-category={post.category}
            >
              {post.coverImage ? (
                <div class="h-44 overflow-hidden">
                  <img src={post.coverImage} alt={post.title} class="w-full h-full object-cover opacity-70 group-hover:opacity-90 group-hover:scale-105 transition-all duration-500" />
                </div>
              ) : (
                <div class={`h-1 w-full bg-gradient-to-r ${categoryStripe[post.category]}`}></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
              <div class="relative p-7 flex flex-col flex-1">
                <div class="flex items-center justify-between mb-5">
                  <span class={`inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full border ${categoryColors[post.category]}`}>
                    <span class="w-1.5 h-1.5 rounded-full bg-current"></span>{post.category}
                  </span>
                </div>
                <h3 class="text-base font-semibold text-white leading-snug mb-3 group-hover:text-indigo-100 transition-colors flex-1">{post.title}</h3>
                <p class="text-sm text-neutral-500 leading-relaxed mb-6 line-clamp-3">{post.excerpt}</p>
                <div class="flex items-center justify-between pt-5 border-t border-neutral-800/70">
                  <span class="text-xs text-neutral-600 rel-date" data-date={post.createdAt}>{post.date}</span>
                  <span class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-400 group-hover:gap-2.5 transition-all">
                    Read
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
      <div id="empty-filter-state" class="hidden text-center py-20">
        <p class="text-neutral-400 text-sm">No articles in this category yet.</p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-neutral-800/50 py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
        <div class="sm:col-span-2 lg:col-span-1">
          <a href="/" class="flex items-center gap-3 mb-4">
            <img src="/logo.svg" alt="amdify.io" class="h-8 w-8 invert" />
            <span class="text-lg font-bold text-white">amdify<span class="text-indigo-400">.io</span></span>
          </a>
          <p class="text-sm text-neutral-500 leading-relaxed mb-4">AI-powered answering machine detection for modern contact centers.</p>
          <p class="text-sm text-neutral-600">&copy; 2026 amdify.io. All rights reserved.</p>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-white mb-4">Product</h4>
          <ul class="space-y-3">
            <li><a href="/#features" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">Features</a></li>
            <li><a href="/#pricing" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">Pricing</a></li>
            <li><a href="/#how-it-works" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">How It Works</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-white mb-4">Company</h4>
          <ul class="space-y-3">
            <li><a href="#" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">About</a></li>
            <li><a href="/blog" class="text-sm text-neutral-300 transition-colors">Blog</a></li>
            <li><a href="mailto:hello@amdify.io" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-white mb-4">Legal</h4>
          <ul class="space-y-3">
            <li><a href="#" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">Privacy Policy</a></li>
            <li><a href="#" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">Terms of Service</a></li>
          </ul>
        </div>
      </div>
    </div>
  </footer>

  <script>
    function relativeTime(iso) {
  if (!iso) return '';
  const diff = Date.now() - new Date(iso).getTime();
  const mins  = Math.floor(diff / 60000);
  const hours = Math.floor(diff / 3600000);
  const days  = Math.floor(diff / 86400000);
  const weeks = Math.floor(days / 7);
  const months= Math.floor(days / 30);
  if (mins < 1)    return 'Just now';
  if (mins < 60)   return `${mins} minute${mins>1?'s':''} ago`;
  if (hours < 24)  return `${hours} hour${hours>1?'s':''} ago`;
  if (days < 7)    return `${days} day${days>1?'s':''} ago`;
  if (weeks < 5)   return `${weeks} week${weeks>1?'s':''} ago`;
  if (months < 12) return `${months} month${months>1?'s':''} ago`;
  return `${Math.floor(months/12)} year${Math.floor(months/12)>1?'s':''} ago`;
}

document.querySelectorAll('.rel-date').forEach(el => {
  const t = relativeTime(el.dataset.date);
  if (t) el.textContent = t;
});

    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar?.classList.toggle('bg-neutral-950/80', window.scrollY > 20);
      navbar?.classList.toggle('backdrop-blur-xl', window.scrollY > 20);
      navbar?.classList.toggle('border-b', window.scrollY > 20);
      navbar?.classList.toggle('border-neutral-800/50', window.scrollY > 20);
    });
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const postCards = document.querySelectorAll<HTMLElement>('.post-card');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        filterBtns.forEach(b => {
          b.classList.remove('bg-indigo-500/15','border-indigo-500/30','text-indigo-300');
          b.classList.add('bg-neutral-900/50','border-neutral-800','text-neutral-400');
        });
        btn.classList.add('bg-indigo-500/15','border-indigo-500/30','text-indigo-300');
        btn.classList.remove('bg-neutral-900/50','border-neutral-800','text-neutral-400');
        let v = 0;
        postCards.forEach(c => {
          const show = filter === 'All' || c.dataset.category === filter;
          c.style.display = show ? '' : 'none';
          if (show) v++;
        });
        const empty = document.getElementById('empty-filter-state');
        if (empty) empty.classList.toggle('hidden', v > 0);

        // PostHog: blog filter applied
        window.posthog?.capture('blog_filter_applied', {
          filter_category: filter,
          visible_posts: v,
        });
      });
    });
    const io = new IntersectionObserver(
      e => e.forEach(x => { if (x.isIntersecting) x.target.classList.add('anim-in'); }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.post-card').forEach(el => {
      el.classList.add('anim-target'); io.observe(el);
    });

    
  </script>
  

  <style>
    .anim-target { opacity:0; transform:translateY(18px); transition:opacity .5s ease-out,transform .5s ease-out; }
    .anim-in    { opacity:1; transform:translateY(0); }
    .line-clamp-3 { display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
    @keyframes wave { 0%,100%{transform:scaleY(1)} 50%{transform:scaleY(.5)} }
    .waveform-bar { animation:wave 1.4s ease-in-out infinite; }
  </style>
</Layout>