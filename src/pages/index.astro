---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ═══════════════════════════ NAVBAR ═══════════════════════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#" class="flex items-center gap-3 group">
        <img src="/logo.svg" alt="amdify.io" class="h-9 w-9 invert" />
        <span class="text-xl font-bold tracking-tight text-white">
          amdify<span class="text-indigo-400">.io</span>
        </span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="#features" class="text-sm text-neutral-400 hover:text-white transition-colors">Features</a>
        <a href="#how-it-works" class="text-sm text-neutral-400 hover:text-white transition-colors">How It Works</a>
        <a href="#pricing" class="text-sm text-neutral-400 hover:text-white transition-colors">Pricing</a>
        <a href="#faq" class="text-sm text-neutral-400 hover:text-white transition-colors">FAQ</a>
      </div>

      <div class="flex items-center gap-3">
        <a href="https://monitor.amdify.io" class="hidden sm:inline-flex text-sm text-neutral-300 hover:text-white transition-colors px-4 py-2">
          Sign In
        </a>
        <a href="#pricing" class="inline-flex items-center gap-2 bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-all hover:shadow-lg hover:shadow-indigo-500/25">
          Get Started
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden text-neutral-400 hover:text-white p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-800 bg-neutral-950/95 backdrop-blur-xl">
      <div class="px-6 py-4 flex flex-col gap-3">
        <a href="#features" class="text-sm text-neutral-400 hover:text-white py-2">Features</a>
        <a href="#how-it-works" class="text-sm text-neutral-400 hover:text-white py-2">How It Works</a>
        <a href="#pricing" class="text-sm text-neutral-400 hover:text-white py-2">Pricing</a>
        <a href="#faq" class="text-sm text-neutral-400 hover:text-white py-2">FAQ</a>
        <a href="https://monitor.amdify.io" class="text-sm text-neutral-400 hover:text-white py-2">Sign In</a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
    <!-- Background effects -->
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-indigo-500/8 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neutral-800 to-transparent"></div>
    </div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.02)_1px,transparent_1px)] bg-[size:64px_64px]"></div>

    <div class="relative max-w-5xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 border border-neutral-800 bg-neutral-900/50 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
        <span class="text-sm text-neutral-400">98.3% accuracy &middot; Sub-200ms response</span>
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6">
        Your Agents Should Talk to
        <span class="relative">
          <span class="bg-gradient-to-r from-indigo-400 via-indigo-300 to-purple-400 bg-clip-text text-transparent">Humans</span>
        </span>,
        <br class="hidden sm:block" />
        Not Voicemails
      </h1>

      <p class="text-lg sm:text-xl text-neutral-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        AI-powered answering machine detection that bolts onto your existing dialer.
        No migration. No disruption. Results in days.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a href="#pricing" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-indigo-500 hover:bg-indigo-400 text-white font-semibold px-8 py-4 rounded-xl transition-all hover:shadow-xl hover:shadow-indigo-500/20 hover:-translate-y-0.5">
          Get in Touch
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="#how-it-works" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-neutral-700 hover:border-neutral-500 text-neutral-300 hover:text-white font-medium px-8 py-4 rounded-xl transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          See How It Works
        </a>
      </div>

      <p class="text-sm text-neutral-500">No contracts &middot; 30-day money-back guarantee &middot; 15-minute setup</p>
    </div>
  </section>

  <!-- ═══════════════════════════ STATS ═══════════════════════════ -->
  <section class="relative py-20 border-y border-neutral-800/50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12">
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-extrabold text-white mb-2">98.3<span class="text-indigo-400">%</span></div>
          <div class="text-sm text-neutral-500 uppercase tracking-wider">AMD Accuracy</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-extrabold text-white mb-2">&lt;200<span class="text-indigo-400">ms</span></div>
          <div class="text-sm text-neutral-500 uppercase tracking-wider">Detection Speed</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-extrabold text-white mb-2">5M<span class="text-indigo-400">+</span></div>
          <div class="text-sm text-neutral-500 uppercase tracking-wider">Monthly Calls</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-extrabold text-white mb-2">15<span class="text-indigo-400">%</span></div>
          <div class="text-sm text-neutral-500 uppercase tracking-wider">Increase in Sales</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-extrabold text-white mb-2">100<span class="text-indigo-400">+</span></div>
          <div class="text-sm text-neutral-500 uppercase tracking-wider">Contact Centers</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ PROBLEM ═══════════════════════════ -->
  <section class="py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-sm font-medium text-indigo-400 tracking-wider uppercase mb-4 block">The Problem</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-6">
          Legacy AMD Is Costing You Money
        </h2>
        <p class="text-lg text-neutral-400 leading-relaxed">
          Traditional voicemail detection is broken. Your agents waste hours listening to voicemail greetings while live prospects slip through the cracks.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="group relative bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-rose-500/30 transition-all">
          <div class="w-12 h-12 bg-rose-500/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">15-25% False Positives</h3>
          <p class="text-neutral-400 leading-relaxed">Default AMD drops live calls by misidentifying humans as voicemails. Every false positive is a lost sale.</p>
        </div>

        <div class="group relative bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-amber-500/30 transition-all">
          <div class="w-12 h-12 bg-amber-500/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Slow Detection</h3>
          <p class="text-neutral-400 leading-relaxed">Legacy systems take 2-4 seconds to decide. By then, live prospects have already said "hello?" twice and hung up.</p>
        </div>

        <div class="group relative bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-orange-500/30 transition-all sm:col-span-2 lg:col-span-1">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Wasted Agent Time</h3>
          <p class="text-neutral-400 leading-relaxed">Your agents spend 30-40% of their time navigating voicemail prompts instead of having conversations that convert.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ FEATURES ═══════════════════════════ -->
  <section id="features" class="py-24 sm:py-32 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/[0.03] to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-sm font-medium text-indigo-400 tracking-wider uppercase mb-4 block">Features</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-6">
          AI That Hears the Difference
        </h2>
        <p class="text-lg text-neutral-400 leading-relaxed">
          Neural networks trained on millions of call recordings. Not rules-based guesswork.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-indigo-500/30 transition-all group">
          <div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Neural AMD Engine</h3>
          <p class="text-neutral-400 leading-relaxed">Deep learning model analyzes audio patterns in real-time, distinguishing human speech from machine greetings with 98.3% accuracy.</p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-indigo-500/30 transition-all group">
          <div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Sub-200ms Detection</h3>
          <p class="text-neutral-400 leading-relaxed">Decisions made in under 200 milliseconds. Your agents connect to live humans before they can say "hello?" a second time.</p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-indigo-500/30 transition-all group">
          <div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Real-Time Dashboard</h3>
          <p class="text-neutral-400 leading-relaxed">Monitor detection rates, agent performance, and call outcomes in real-time. Complete visibility into every decision.</p>
        </div>

        <!-- Feature 4 -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-indigo-500/30 transition-all group">
          <div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Bolt-On Integration</h3>
          <p class="text-neutral-400 leading-relaxed">Works with VICIdial, FreePBX, Asterisk, and any SIP-based dialer. API-first design means zero migration required.</p>
        </div>

        <!-- Feature 5 -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-indigo-500/30 transition-all group">
          <div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Advanced Analytics</h3>
          <p class="text-neutral-400 leading-relaxed">Deep insights into connect rates, disposition accuracy, and campaign performance. Know exactly where your ROI is coming from.</p>
        </div>

        <!-- Feature 6 -->
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 hover:border-indigo-500/30 transition-all group">
          <div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">Enterprise Security</h3>
          <p class="text-neutral-400 leading-relaxed">Your data stays on your servers. API-based processing with no call recording storage. SOC 2 compliant infrastructure.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ HOW IT WORKS ═══════════════════════════ -->
  <section id="how-it-works" class="py-24 sm:py-32 border-y border-neutral-800/50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-sm font-medium text-indigo-400 tracking-wider uppercase mb-4 block">How It Works</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-6">
          Three Steps. Fifteen Minutes.
        </h2>
        <p class="text-lg text-neutral-400 leading-relaxed">
          Go from setup to live detection faster than your coffee gets cold.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Step 1 -->
        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl flex items-center justify-center shrink-0">
              <span class="text-2xl font-bold text-indigo-400">1</span>
            </div>
            <div class="hidden md:block flex-1 h-px bg-gradient-to-r from-indigo-500/30 to-transparent"></div>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Connect Your Dialer</h3>
          <p class="text-neutral-400 leading-relaxed">
            Point your SIP traffic through our API endpoint. Works with any SIP-based dialer — VICIdial, FreePBX, Asterisk, or custom setups. Takes 15 minutes.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl flex items-center justify-center shrink-0">
              <span class="text-2xl font-bold text-indigo-400">2</span>
            </div>
            <div class="hidden md:block flex-1 h-px bg-gradient-to-r from-indigo-500/30 to-transparent"></div>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">AI Analyzes Every Call</h3>
          <p class="text-neutral-400 leading-relaxed">
            Our neural network listens to the first moments of each call, classifying it as human or machine in under 200ms. No agent intervention needed.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl flex items-center justify-center shrink-0">
              <span class="text-2xl font-bold text-indigo-400">3</span>
            </div>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Agents Talk to Humans</h3>
          <p class="text-neutral-400 leading-relaxed">
            Voicemails are handled automatically. Live calls are routed to agents instantly. Watch your connect rates climb and cost-per-lead drop from day one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ COMPARISON ═══════════════════════════ -->
  <section class="py-24 sm:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-sm font-medium text-indigo-400 tracking-wider uppercase mb-4 block">Why amdify.io</span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6">
          Legacy AMD vs. amdify.io
        </h2>
      </div>

      <div class="overflow-hidden rounded-2xl border border-neutral-800">
        <table class="w-full">
          <thead>
            <tr class="border-b border-neutral-800 bg-neutral-900/50">
              <th class="text-left text-sm font-medium text-neutral-400 px-6 py-4"></th>
              <th class="text-center text-sm font-medium text-neutral-500 px-6 py-4">Legacy AMD</th>
              <th class="text-center text-sm font-medium text-indigo-400 px-6 py-4">amdify.io</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800/50">
            <tr>
              <td class="px-6 py-4 text-sm text-neutral-300">Accuracy</td>
              <td class="px-6 py-4 text-center text-sm text-neutral-500">~75-80%</td>
              <td class="px-6 py-4 text-center text-sm text-white font-medium">98.3%</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm text-neutral-300">Detection Speed</td>
              <td class="px-6 py-4 text-center text-sm text-neutral-500">2-4 seconds</td>
              <td class="px-6 py-4 text-center text-sm text-white font-medium">&lt;200ms</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm text-neutral-300">Technology</td>
              <td class="px-6 py-4 text-center text-sm text-neutral-500">Rules-based</td>
              <td class="px-6 py-4 text-center text-sm text-white font-medium">Neural Network</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm text-neutral-300">Integration</td>
              <td class="px-6 py-4 text-center text-sm text-neutral-500">Built-in only</td>
              <td class="px-6 py-4 text-center text-sm text-white font-medium">Any SIP Dialer</td>
            </tr>
