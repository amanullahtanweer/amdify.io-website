---
import fs from 'fs';
import path from 'path';
const DATA_FILE = path.join(process.cwd(), 'src/data/posts.json');
const existingPosts = fs.existsSync(DATA_FILE) ? JSON.parse(fs.readFileSync(DATA_FILE, 'utf-8')) : [];
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Blog Admin — amdify.io</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{background:#080d18;color:#e5e5e5;font-family:'DM Sans',sans-serif;font-size:14px}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:#0f172a}::-webkit-scrollbar-thumb{background:#374151;border-radius:3px}
.topbar{border-bottom:1px solid #1f2937;padding:.75rem 1.25rem;display:flex;align-items:center;justify-content:space-between;background:#080d18;position:sticky;top:0;z-index:100}
.tabs{display:flex;border-bottom:1px solid #1f2937;padding:0 1.25rem}
.tab{padding:.75rem 1rem;font-size:.8rem;font-weight:500;color:#6b7280;cursor:pointer;border-bottom:2px solid transparent;transition:color .2s,border-color .2s;white-space:nowrap}
.tab.active{color:#818cf8;border-bottom-color:#818cf8}
.tab:hover:not(.active){color:#d4d4d4}
.panel{display:none;padding:1.25rem}.panel.active{display:block}
.grid{display:grid;grid-template-columns:1fr 320px;gap:1.25rem;max-width:1280px;margin:0 auto}
@media(max-width:1024px){.grid{grid-template-columns:1fr}}
.card{background:#0c1424;border:1px solid #1f2937;border-radius:.875rem;padding:1.125rem;margin-bottom:1rem}
.card-hd{font-size:.72rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.875rem;display:flex;align-items:center;gap:.5rem}
.card-hd svg{color:#6366f1;width:14px;height:14px;flex-shrink:0}
.field{margin-bottom:.875rem}
.field label{display:block;font-size:.68rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.3rem}
.field input,.field select,.field textarea{width:100%;background:#080d18;border:1px solid #1f2937;border-radius:.5rem;padding:.5rem .75rem;font-size:.875rem;color:#e5e5e5;font-family:'DM Sans',sans-serif;transition:border-color .2s;outline:none}
.field input:focus,.field select:focus,.field textarea:focus{border-color:rgba(99,102,241,.5)}
.field select option{background:#0c1424}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:.875rem}
@media(max-width:640px){.field-row{grid-template-columns:1fr}}
.char-count{font-size:.65rem;color:#4b5563;text-align:right;margin-top:.2rem}
.char-count.warn{color:#f59e0b}
.hint{font-size:.68rem;color:#4b5563;margin-top:.25rem}
/* Upload */
.upload-zone{border:2px dashed #1f2937;border-radius:.875rem;padding:1.5rem;text-align:center;cursor:pointer;transition:all .2s;background:#0a0f1e;margin-bottom:.875rem}
.upload-zone:hover,.upload-zone.drag-over{border-color:rgba(99,102,241,.5);background:rgba(99,102,241,.03)}
.upload-zone.has-file{border-color:rgba(16,185,129,.4)}
.file-status{display:none;background:#0c1424;border:1px solid #1f2937;border-radius:.75rem;padding:.75rem 1rem;margin-bottom:.875rem;align-items:center;gap:.625rem}
.file-status.show{display:flex}
.file-badge{width:2rem;height:2rem;border-radius:.375rem;display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:800;flex-shrink:0}
.file-badge.pdf{background:rgba(239,68,68,.12);color:#f87171}
.file-badge.docx{background:rgba(37,99,235,.12);color:#60a5fa}
.file-badge.txt{background:rgba(16,185,129,.12);color:#34d399}
.progress-wrap{display:none;margin-bottom:.875rem}
.progress-wrap.show{display:block}
.progress-lbl{font-size:.72rem;color:#818cf8;margin-bottom:.375rem;display:flex;align-items:center;gap:.375rem}
.progress-bar{height:.3rem;background:#1f2937;border-radius:999px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,#6366f1,#8b5cf6,#6366f1);background-size:200% 100%;border-radius:999px;transition:width .4s;animation:shimmer 1.5s linear infinite}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:0 0}}
/* Paste banner */
.paste-banner{display:none;background:linear-gradient(135deg,rgba(99,102,241,.1),rgba(139,92,246,.07));border:1px solid rgba(99,102,241,.25);border-radius:.75rem;padding:.875rem 1rem;margin-bottom:.875rem;align-items:center;gap:.75rem}
.paste-banner.show{display:flex}
/* Editor */
.editor-wrap{border:1px solid #1f2937;border-radius:.75rem;overflow:hidden;background:#080d18}
.toolbar{display:flex;align-items:center;gap:2px;padding:.5rem .625rem;border-bottom:1px solid #1f2937;background:#0c1424;flex-wrap:wrap}
.tb-sep{width:1px;height:1.125rem;background:#1f2937;margin:0 .2rem;flex-shrink:0}
.tb-btn{display:inline-flex;align-items:center;justify-content:center;gap:.25rem;background:none;border:none;color:#6b7280;cursor:pointer;border-radius:.375rem;padding:.3rem .45rem;font-size:.75rem;font-weight:600;white-space:nowrap;transition:all .15s;font-family:'DM Sans',sans-serif}
.tb-btn:hover{background:rgba(99,102,241,.12);color:#e5e5e5}
.tb-btn svg{width:13px;height:13px;flex-shrink:0}
.tb-btn.highlight{background:rgba(99,102,241,.15);color:#818cf8;border:1px solid rgba(99,102,241,.2)}
.tb-sel{background:#080d18;border:1px solid #1f2937;border-radius:.375rem;color:#9ca3af;font-size:.75rem;font-family:'DM Sans',sans-serif;padding:.25rem .5rem;cursor:pointer;outline:none}
.tb-sel:focus{border-color:rgba(99,102,241,.5)}
#editor{min-height:400px;padding:1rem 1.125rem;font-size:.9375rem;line-height:1.85;color:#d4d4d4;outline:none;font-family:'DM Sans',sans-serif}
#editor:empty::before{content:attr(data-placeholder);color:#374151;pointer-events:none;white-space:pre-line}
#editor h2{font-size:1.25rem;font-weight:700;color:#fff;margin:1.75rem 0 .75rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,.06);font-family:'Syne',sans-serif}
#editor h3{font-size:1.0625rem;font-weight:600;color:#c7d2fe;margin:1.25rem 0 .5rem}
#editor h4{font-size:.9375rem;font-weight:600;color:#a5b4fc;margin:.875rem 0 .375rem}
#editor p{margin-bottom:.875rem}
#editor strong{color:#fff;font-weight:600}
#editor em{color:#d4d4d4;font-style:italic}
#editor code{background:rgba(99,102,241,.12);color:#a5b4fc;padding:.1em .4em;border-radius:4px;font-family:monospace;font-size:.875em}
#editor blockquote{border-left:3px solid rgba(99,102,241,.6);padding:.625rem 1rem;background:rgba(99,102,241,.05);border-radius:0 .5rem .5rem 0;color:#d4d4d4;font-style:italic;margin:.875rem 0}
#editor ul{list-style:disc;padding-left:1.5rem;margin-bottom:.875rem}
#editor ol{list-style:decimal;padding-left:1.5rem;margin-bottom:.875rem}
#editor li{margin-bottom:.3rem}
#editor table{width:100%;border-collapse:collapse;margin:1rem 0;border:1px solid #1f2937;border-radius:.5rem;overflow:hidden}
#editor th{background:rgba(15,23,42,.9);color:#e5e5e5;font-weight:600;padding:.5rem .875rem;text-align:left;border-bottom:1px solid #374151;font-size:.875rem}
#editor td{padding:.5rem .875rem;border-bottom:1px solid #1f2937;color:#a3a3a3;font-size:.875rem}
#editor tr:last-child td{border-bottom:none}
#editor hr{border:none;border-top:1px solid #1f2937;margin:1.25rem 0}
.editor-footer{display:flex;align-items:center;justify-content:space-between;padding:.375rem .75rem;border-top:1px solid #1f2937;background:#0c1424}
.editor-footer span{font-size:.68rem;color:#4b5563}
/* Modals */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;align-items:center;justify-content:center}
.overlay.show{display:flex}
.modal{background:#0c1424;border:1px solid #374151;border-radius:1rem;padding:1.5rem;width:520px;max-width:95vw;max-height:90vh;overflow-y:auto}
.modal h3{font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:#fff;margin-bottom:1rem}
/* Smart table modal */
.smart-table-input{width:100%;background:#080d18;border:1px solid #1f2937;border-radius:.5rem;padding:.75rem;font-size:.8125rem;color:#e5e5e5;font-family:'Fira Code',monospace;min-height:120px;outline:none;resize:vertical}
.smart-table-input:focus{border-color:rgba(99,102,241,.5)}
.table-preview-wrap{background:#080d18;border:1px solid #1f2937;border-radius:.5rem;overflow-x:auto;margin:1rem 0;min-height:60px;padding:.5rem}
.table-preview-wrap table{width:100%;border-collapse:collapse;font-size:.8125rem}
.table-preview-wrap th{background:rgba(99,102,241,.1);color:#818cf8;font-weight:600;padding:.4rem .75rem;text-align:left;border:1px solid #1f2937}
.table-preview-wrap td{padding:.4rem .75rem;border:1px solid #1f2937;color:#d4d4d4}
.table-preview-wrap td[contenteditable]{outline:none}
.table-preview-wrap td[contenteditable]:focus{background:rgba(99,102,241,.05)}
.table-preview-wrap th[contenteditable]{outline:none}
.hint-tip{font-size:.72rem;color:#6b7280;background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.12);border-radius:.5rem;padding:.5rem .75rem;margin-bottom:.875rem;line-height:1.6}
/* SEO preview */
.seo-preview{background:#080d18;border:1px solid #1f2937;border-radius:.625rem;padding:.875rem;margin-top:.5rem}
.seo-url{font-size:.7rem;color:#34d399;margin-bottom:.2rem}
.seo-title-p{font-size:.9375rem;color:#818cf8;font-weight:500;margin-bottom:.2rem;line-height:1.3}
.seo-desc-p{font-size:.78rem;color:#9ca3af;line-height:1.5}
/* Card preview */
/* Buttons */
.btn{display:inline-flex;align-items:center;gap:.375rem;font-size:.8rem;font-weight:600;padding:.5rem 1rem;border-radius:.5rem;border:none;cursor:pointer;transition:all .15s;font-family:'DM Sans',sans-serif}
.btn-primary{background:#6366f1;color:#fff}
.btn-primary:hover:not(:disabled){background:#818cf8;transform:translateY(-1px);box-shadow:0 4px 16px rgba(99,102,241,.3)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none}
.btn-full{width:100%;justify-content:center;padding:.8rem;font-size:.875rem}
.btn-ghost{background:rgba(99,102,241,.08);color:#818cf8;border:1px solid rgba(99,102,241,.2)}
.btn-ghost:hover{background:rgba(99,102,241,.15)}
.btn-danger{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);font-size:.72rem;padding:.3rem .625rem}
.btn-danger:hover{background:rgba(239,68,68,.2)}
.btn-sm{padding:.3rem .625rem;font-size:.72rem}
/* Posts */
.post-row{display:flex;align-items:center;gap:.875rem;background:#0c1424;border:1px solid #1f2937;border-radius:.75rem;padding:.875rem 1rem;margin-bottom:.5rem}
.post-row:hover{border-color:#374151}
.post-info{flex:1;min-width:0}
.post-title-text{font-size:.875rem;font-weight:600;color:#e5e5e5;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:.2rem}
.post-meta{display:flex;align-items:center;gap:.375rem;flex-wrap:wrap}
.tag{display:inline-flex;font-size:.62rem;font-weight:700;padding:.15rem .5rem;border-radius:999px}
.tag-industry{background:rgba(244,63,94,.1);color:#fb7185}
.tag-technology{background:rgba(99,102,241,.1);color:#818cf8}
.tag-guides{background:rgba(16,185,129,.1);color:#34d399}
.tag-featured{background:rgba(245,158,11,.1);color:#fbbf24}
#toast{position:fixed;bottom:1.25rem;right:1.25rem;padding:.625rem 1rem;border-radius:.625rem;font-size:.8rem;font-weight:500;transform:translateY(4rem);opacity:0;transition:all .3s;z-index:999;pointer-events:none}
#toast.show{transform:translateY(0);opacity:1}
#toast.success{background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);color:#34d399}
#toast.error{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#f87171}
.empty-state{text-align:center;padding:2.5rem 1rem;color:#4b5563;font-size:.875rem}
@keyframes spin{to{transform:rotate(360deg)}}
.spinning{animation:spin 1s linear infinite}

/* Edit modal wide */
.modal-wide{width:800px;max-width:96vw;}
#edit-editor{min-height:260px;padding:1rem;font-size:.9rem;line-height:1.8;color:#d4d4d4;outline:none;font-family:'DM Sans',sans-serif;}
#edit-editor h2{font-size:1.2rem;font-weight:700;color:#fff;margin:1.5rem 0 .6rem;border-top:1px solid rgba(255,255,255,.06);padding-top:1rem;}
#edit-editor h3{font-size:1rem;font-weight:600;color:#c7d2fe;margin:1.1rem 0 .4rem;}
#edit-editor p{margin-bottom:.8rem;}
#edit-editor strong{color:#fff;font-weight:600;}
#edit-editor em{font-style:italic;}
#edit-editor ul{list-style:disc;padding-left:1.5rem;margin-bottom:.8rem;}
#edit-editor ol{list-style:decimal;padding-left:1.5rem;margin-bottom:.8rem;}
#edit-editor li{margin-bottom:.25rem;}
#edit-editor blockquote{border-left:3px solid rgba(99,102,241,.6);padding:.5rem 1rem;background:rgba(99,102,241,.05);border-radius:0 .5rem .5rem 0;color:#d4d4d4;font-style:italic;margin:.8rem 0;}
#edit-editor table{width:100%;border-collapse:collapse;margin:.8rem 0;border:1px solid #1f2937;}
#edit-editor th{background:rgba(15,23,42,.9);color:#e5e5e5;font-weight:600;padding:.4rem .75rem;text-align:left;border-bottom:1px solid #374151;}
#edit-editor td{padding:.4rem .75rem;border-bottom:1px solid #1f2937;color:#a3a3a3;}
</style>
</head>
<body>

<header class="topbar">
  <div style="display:flex;align-items:center;gap:.75rem;">
    <a href="/" style="display:flex;align-items:center;gap:.5rem;text-decoration:none;">
      <img src="/logo.svg" style="height:1.75rem;width:1.75rem;filter:invert(1);" alt=""/>
      <span style="font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:#fff;">amdify<span style="color:#818cf8;">.io</span></span>
    </a>
    <span style="color:#374151;">/</span>
    <span style="font-size:.78rem;color:#6b7280;">Blog Admin</span>
  </div>
  <div style="display:flex;align-items:center;gap:.625rem;">
    <span id="hdr-count" style="font-size:.72rem;color:#4b5563;">{existingPosts.length} posts</span>
    <a href="/blog" target="_blank" style="font-size:.72rem;color:#818cf8;text-decoration:none;border:1px solid rgba(99,102,241,.25);padding:.3rem .75rem;border-radius:.4rem;display:flex;align-items:center;gap:.3rem;">View Blog <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></a>
  </div>
</header>

<div class="tabs">
  <div class="tab active" onclick="switchTab('write')">✍️ Write Post</div>
  <div class="tab" onclick="switchTab('posts')">📋 Posts (<span id="tab-count">{existingPosts.length}</span>)</div>
</div>

<!-- WRITE -->
<div class="panel active" id="panel-write">
<div class="grid">
<div>

  <!-- Upload -->
  <div class="card">
    <div class="card-hd"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>Upload File — AI formats everything</div>
    <input type="file" id="file-input" accept=".docx,.pdf,.txt" style="display:none"/>
    <div class="upload-zone" id="upload-zone" onclick="document.getElementById('file-input').click()">
      <div style="font-size:.875rem;font-weight:600;color:#9ca3af;margin-bottom:.25rem;">Drag & drop or click to upload</div>
      <div style="display:flex;justify-content:center;gap:.375rem;margin:.5rem 0;">
        <span style="font-size:.62rem;font-weight:700;padding:.15rem .5rem;border-radius:.3rem;background:rgba(37,99,235,.12);color:#60a5fa;border:1px solid rgba(37,99,235,.2);">DOCX</span>
        <span style="font-size:.62rem;font-weight:700;padding:.15rem .5rem;border-radius:.3rem;background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.18);">PDF</span>
        <span style="font-size:.62rem;font-weight:700;padding:.15rem .5rem;border-radius:.3rem;background:rgba(16,185,129,.1);color:#34d399;border:1px solid rgba(16,185,129,.18);">TXT</span>
      </div>
      <div style="font-size:.68rem;color:#4b5563;">Headings, tables, bullets auto-detected</div>
    </div>
    <div class="file-status" id="file-status">
      <div class="file-badge docx" id="file-badge">DOC</div>
      <div style="flex:1;min-width:0;"><div style="font-size:.8125rem;font-weight:600;color:#e5e5e5;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="file-name">file.docx</div><div style="font-size:.7rem;color:#6b7280;" id="file-size">reading...</div></div>
      <button onclick="clearFile()" style="background:none;border:none;color:#6b7280;cursor:pointer;"><svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
    </div>
    <div class="progress-wrap" id="progress-wrap">
      <div class="progress-lbl" id="progress-lbl"><svg class="spinning" width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Processing...</div>
      <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:15%"></div></div>
    </div>
  </div>

  <!-- Post details -->
  <div class="card">
    <div class="card-hd"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Post Details</div>
    <div class="field"><label>Title *</label><input type="text" id="title" placeholder="Post title..." maxlength="120" oninput="syncSlug();updateCount('title','tc',120);updatePreviews();"/><div class="char-count" id="tc">0/120</div></div>
    <div class="field-row">
      <div class="field" style="margin-bottom:0;"><label>Category *</label><select id="category" onchange="updatePreviews()"><option value="">Select...</option><option value="Technology">Technology</option><option value="Industry">Industry</option><option value="Guides">Guides</option></select></div>
      <div class="field" style="margin-bottom:0;"><label>Author</label><input type="text" id="author" placeholder="amdify.io Team"/></div>
    </div>
    <div class="field" style="margin-top:.875rem;"><label>Slug</label><input type="text" id="slug" placeholder="auto-from-title" oninput="slugManual=true;updatePreviews();"/><div class="hint">amdify.io/blog/<span id="slug-preview" style="color:#818cf8;">your-slug</span></div></div>
    <div class="field"><label>Excerpt</label><textarea id="excerpt" rows="2" placeholder="Auto-generated if empty..." maxlength="200" oninput="updateCount('excerpt','ec',200);updatePreviews();"></textarea><div class="char-count" id="ec">0/200</div></div>
    <div class="field"><label>Cover Image URL <span style="color:#4b5563;">(optional)</span></label><input type="text" id="coverImage" placeholder="/blog/cover.jpg"/></div>
  </div>

  <!-- Editor -->
  <div class="card" style="padding:.875rem;">
    <div class="card-hd"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>Content Editor</div>

    <!-- Paste banner -->
    <div class="paste-banner" id="paste-banner">
      <div style="width:2.25rem;height:2.25rem;background:rgba(99,102,241,.15);border:1px solid rgba(99,102,241,.3);border-radius:.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="16" height="16" fill="none" stroke="#818cf8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      </div>
      <div style="flex:1;font-size:.8rem;color:#c7d2fe;"><strong style="color:#fff;display:block;margin-bottom:.1rem;" id="paste-title">Plain text pasted</strong><span id="paste-sub">Click to format headings automatically</span></div>
      <button class="btn btn-ghost btn-sm" id="paste-ai-btn" onclick="formatEditorContent()">Format Headings</button>
    </div>

    <div class="editor-wrap">
      <div class="toolbar">
        <select class="tb-sel" onchange="applyBlock(this.value);this.value=''">
          <option value="">Style...</option>
          <option value="h2">H2 — Main Section</option>
          <option value="h3">H3 — Sub-section</option>
          <option value="h4">H4 — Minor</option>
