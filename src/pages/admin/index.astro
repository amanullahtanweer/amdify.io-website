  finally {
    btn.disabled = false;
    btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Save Changes';
  }
}
window.saveEdit = saveEdit;

function refreshPostRow(oldSlug, post) {
  const row = document.getElementById('row-'+oldSlug);
  if (!row) return;
  row.id = 'row-'+post.slug;
  const cc = {Technology:'tag-technology',Industry:'tag-industry',Guides:'tag-guides'};
  row.innerHTML = `<div class="post-info"><div class="post-title-text">${post.title}</div><div class="post-meta"><span class="tag ${cc[post.category]||'tag-technology'}">${post.category}</span>${post.featured?'<span class="tag tag-featured">Featured</span>':''}<span style="font-size:.68rem;color:#4b5563;">${post.date||''}</span><span style="font-size:.68rem;color:#4b5563;">${post.readTime||''}</span></div></div><div style="display:flex;gap:.375rem;flex-shrink:0;"><button class="btn btn-ghost btn-sm" onclick="openEditModal('${post.slug}')">✏️ Edit</button><a href="/blog/${post.slug}" target="_blank" style="font-size:.72rem;color:#818cf8;text-decoration:none;border:1px solid rgba(99,102,241,.2);padding:.3rem .625rem;border-radius:.4rem;">View</a><button class="btn btn-danger" onclick="deletePost('${post.slug}')">Delete</button></div>`;
}

function editorToMarkdownFrom(editorId) {
  function n2md(node){
    if(node.nodeType===3)return node.textContent;
    const tag=node.tagName?.toLowerCase();
    const inner=Array.from(node.childNodes).map(n2md).join('');
    if(tag==='h1'||tag==='h2')return`\n## ${inner}\n\n`;
    if(tag==='h3')return`\n### ${inner}\n\n`;
    if(tag==='h4')return`\n#### ${inner}\n\n`;
    if(tag==='p')return`${inner}\n\n`;
    if(tag==='br')return'\n';
    if(tag==='strong'||tag==='b')return`**${inner}**`;
    if(tag==='em'||tag==='i')return`*${inner}*`;
    if(tag==='code')return'`'+inner+'`';
    if(tag==='blockquote')return`\n> ${inner.trim()}\n\n`;
    if(tag==='hr')return`\n---\n\n`;
    if(tag==='ul')return'\n'+Array.from(node.querySelectorAll(':scope>li')).map(li=>`- ${li.innerText.trim()}`).join('\n')+'\n\n';
    if(tag==='ol')return'\n'+Array.from(node.querySelectorAll(':scope>li')).map((li,i)=>`${i+1}. ${li.innerText.trim()}`).join('\n')+'\n\n';
    if(tag==='table'){
      const rows=Array.from(node.querySelectorAll('tr'));if(!rows.length)return'';
      const hdr=Array.from(rows[0].querySelectorAll('th,td')).map(c=>c.innerText.trim());
      let md='| '+hdr.join(' | ')+' |\n'+'| '+hdr.map(()=>'---').join(' | ')+' |\n';
      for(let i=1;i<rows.length;i++)md+='| '+Array.from(rows[i].querySelectorAll('td')).map(c=>c.innerText.trim()).join(' | ')+' |\n';
      return'\n'+md+'\n';
    }
    return inner;
  }
  const editor=document.getElementById(editorId);
  if(!editor)return'';
  return Array.from(editor.childNodes).map(n2md).join('').replace(/\n{3,}/g,'\n\n').trim();
}

</script>

<!-- ═══ EDIT MODAL ═══ -->
<div class="overlay" id="edit-modal">
  <div class="modal modal-wide">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
      <h3 style="margin-bottom:0;">✏️ Edit Post</h3>
      <button onclick="closeEditModal()" style="background:none;border:none;color:#6b7280;cursor:pointer;font-size:1.25rem;line-height:1;">✕</button>
    </div>
    <input type="hidden" id="edit-original-slug"/>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.875rem;margin-bottom:.875rem;">
      <div class="field" style="margin-bottom:0;"><label>Title *</label><input type="text" id="edit-title" maxlength="120" oninput="editSyncSlug();updateCount('edit-title','edit-tc',120);"/><div class="char-count" id="edit-tc">0/120</div></div>
      <div class="field" style="margin-bottom:0;"><label>Slug</label><input type="text" id="edit-slug" oninput="editSlugManual=true;document.getElementById('edit-slug-preview').textContent=this.value||'slug';"/><div class="hint">amdify.io/blog/<span id="edit-slug-preview" style="color:#818cf8;">slug</span></div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.875rem;margin-bottom:.875rem;">
      <div class="field" style="margin-bottom:0;"><label>Category *</label><select id="edit-category"><option value="Technology">Technology</option><option value="Industry">Industry</option><option value="Guides">Guides</option></select></div>
      <div class="field" style="margin-bottom:0;"><label>Author</label><input type="text" id="edit-author"/></div>
    </div>
    <div class="field"><label>Excerpt</label><textarea id="edit-excerpt" rows="2" maxlength="200" oninput="updateCount('edit-excerpt','edit-ec',200);"></textarea><div class="char-count" id="edit-ec">0/200</div></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.875rem;margin-bottom:.875rem;">
      <div class="field" style="margin-bottom:0;"><label>SEO Title <span style="color:#4b5563;">(60-65 chars)</span></label><input type="text" id="edit-seo-title" maxlength="70" oninput="updateCount('edit-seo-title','edit-stc',65);"/><div class="char-count" id="edit-stc">0/65</div></div>
      <div class="field" style="margin-bottom:0;"><label>Cover Image URL</label><input type="text" id="edit-cover" placeholder="/blog/cover.jpg"/></div>
    </div>
    <div class="field"><label>Meta Description <span style="color:#4b5563;">(150-160 chars)</span></label><textarea id="edit-seo-desc" rows="2" maxlength="170" oninput="updateCount('edit-seo-desc','edit-sdc',160);"></textarea><div class="char-count" id="edit-sdc">0/160</div></div>
    <div class="field">
      <label>Content</label>
      <div class="editor-wrap">
        <div class="toolbar">
          <select class="tb-sel" onchange="editApplyBlock(this.value);this.value=''"><option value="">Style...</option><option value="h2">H2</option><option value="h3">H3</option><option value="h4">H4</option><option value="p">¶ Para</option></select>
          <div class="tb-sep"></div>
          <button class="tb-btn" onclick="editExec('bold')"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 12h8a4 4 0 000-8H6v8zm0 0h9a4 4 0 010 8H6v-8z"/></svg></button>
          <button class="tb-btn" onclick="editExec('italic')"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 4h-9M14 20H5M14.5 4.5l-5 15"/></svg></button>
          <div class="tb-sep"></div>
          <button class="tb-btn" onclick="editExec('insertUnorderedList')">• List</button>
          <button class="tb-btn" onclick="editExec('insertOrderedList')">1. List</button>
          <button class="tb-btn" onclick="editApplyBlock('blockquote')">" Quote</button>
        </div>
        <div id="edit-editor" contenteditable="true" data-placeholder="Post content..."></div>
        <div class="editor-footer"><span id="edit-word-count">0 words</span></div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
      <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.8125rem;color:#9ca3af;"><input type="checkbox" id="edit-featured" style="accent-color:#6366f1;"/> Featured post</label>
    </div>
    <div id="edit-err" style="display:none;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:.5rem;padding:.5rem .875rem;font-size:.78rem;color:#f87171;margin-bottom:.875rem;"></div>
    <div style="display:flex;gap:.625rem;justify-content:flex-end;">
      <button class="btn btn-ghost" onclick="closeEditModal()">Cancel</button>
      <button class="btn btn-primary" id="edit-save-btn" onclick="saveEdit()">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Save Changes
      </button>
    </div>
  </div>
</div>

</body>
