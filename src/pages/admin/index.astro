// ── Markdown → Editor HTML ────────────────────────────
function markdownToHtml(md){
  if(!md)return'';
  const lines=md.split('\n');let html='',inTbl=false,tblHtml='',tblHdr=false;
  for(let i=0;i<lines.length;i++){
    const line=lines[i];
    if(line.startsWith('|')){
      if(!inTbl){inTbl=true;tblHtml='<table>';tblHdr=false;}
      const cells=line.split('|').slice(1,-1).map(c=>c.trim());
      const isSep=cells.every(c=>/^[-:]+$/.test(c));
      if(isSep){tblHtml+='</thead><tbody>';tblHdr=true;}
      else if(!tblHdr){tblHtml+=`<thead><tr>${cells.map(c=>`<th>${c}</th>`).join('')}</tr>`;}
      else{tblHtml+=`<tr>${cells.map(c=>`<td>${c}</td>`).join('')}</tr>`;}
      if(i===lines.length-1||!lines[i+1]?.startsWith('|')){tblHtml+='</tbody></table>';html+=tblHtml;inTbl=false;tblHtml='';tblHdr=false;}
      continue;
    }
    if(inTbl){tblHtml+='</tbody></table>';html+=tblHtml;inTbl=false;tblHtml='';tblHdr=false;}
    const l=line.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/`(.+?)`/g,'<code>$1</code>');
    if(line.startsWith('#### ')) html+=`<h4>${l.slice(5)}</h4>`;
    else if(line.startsWith('### ')) html+=`<h3>${l.slice(4)}</h3>`;
    else if(line.startsWith('## '))  html+=`<h2>${l.slice(3)}</h2>`;
    else if(line.startsWith('# '))   html+=`<h2>${l.slice(2)}</h2>`;
    else if(line.startsWith('> '))   html+=`<blockquote>${l.slice(2)}</blockquote>`;
    else if(line.startsWith('- '))   html+=`<ul><li>${l.slice(2)}</li></ul>`;
    else if(/^\d+\. /.test(line))    html+=`<ol><li>${l.replace(/^\d+\. /,'')}</li></ol>`;
    else if(line==='---')            html+=`<hr/>`;
    else if(!line.trim())            html+=`<p><br></p>`;
    else                             html+=`<p>${l}</p>`;
  }
  return html.replace(/<\/ul><ul>/g,'').replace(/<\/ol><ol>/g,'');
}

// ── Editor → Markdown ─────────────────────────────────
function editorToMarkdown(){
  function n2md(node){
    if(node.nodeType===3)return node.textContent;
    const tag=node.tagName?.toLowerCase();
    const inner=Array.from(node.childNodes).map(n2md).join('');
    if(tag==='h1'||tag==='h2')return`\n## ${inner}\n\n`;
    if(tag==='h3')return`\n### ${inner}\n\n`;
    if(tag==='h4')return`\n#### ${inner}\n\n`;
    if(tag==='p')return`${inner}\n\n`;
    if(tag==='br')return'\n';
    if(tag==='strong'||tag==='b')return`**${inner}**`;
    if(tag==='em'||tag==='i')return`*${inner}*`;
    if(tag==='code')return`\`${inner}\``;
    if(tag==='blockquote')return`\n> ${inner.trim()}\n\n`;
    if(tag==='hr')return`\n---\n\n`;
    if(tag==='ul')return'\n'+Array.from(node.querySelectorAll(':scope>li')).map(li=>`- ${li.innerText.trim()}`).join('\n')+'\n\n';
    if(tag==='ol')return'\n'+Array.from(node.querySelectorAll(':scope>li')).map((li,i)=>`${i+1}. ${li.innerText.trim()}`).join('\n')+'\n\n';
    if(tag==='table'){
      const rows=Array.from(node.querySelectorAll('tr'));if(!rows.length)return'';
      const hdr=Array.from(rows[0].querySelectorAll('th,td')).map(c=>c.innerText.trim());
      let md='| '+hdr.join(' | ')+' |\n'+'| '+hdr.map(()=>'---').join(' | ')+' |\n';
      for(let i=1;i<rows.length;i++)md+='| '+Array.from(rows[i].querySelectorAll('td')).map(c=>c.innerText.trim()).join(' | ')+' |\n';
      return'\n'+md+'\n';
    }
    return inner;
  }
  return Array.from(document.getElementById('editor').childNodes).map(n2md).join('').replace(/\n{3,}/g,'\n\n').trim();
}

