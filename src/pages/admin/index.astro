<div id="toast"></div>

<script>
if(typeof pdfjsLib!=='undefined') pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

// ── Tabs ──────────────────────────────────────────────
function switchTab(n){document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',['write','posts'][i]===n));document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));document.getElementById(`panel-${n}`)?.classList.add('active');}
window.switchTab=switchTab;
function toast(msg,type='success'){const t=document.getElementById('toast');t.textContent=msg;t.className=`show ${type}`;setTimeout(()=>{t.className='';},4000);}
function updateCount(id,cid,max){const n=document.getElementById(id).value.length;const el=document.getElementById(cid);el.textContent=`${n}/${max}`;el.className=`char-count${n>max*.85?' warn':''}`;}
window.updateCount=updateCount;
let slugManual=false;
function slugify(s){return s.toLowerCase().replace(/[^a-z0-9\s]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').replace(/(^-|-$)/g,'').slice(0,80);}
function syncSlug(){if(slugManual)return;const s=slugify(document.getElementById('title').value);document.getElementById('slug').value=s;document.getElementById('slug-preview').textContent=s||'your-slug';}
window.syncSlug=syncSlug;
function readTime(t){return Math.max(1,Math.ceil(t.trim().split(/\s+/).filter(Boolean).length/200));}

function updatePreviews(){
  const title=document.getElementById('title').value;
  const excerpt=document.getElementById('excerpt').value;
  const cat=document.getElementById('category').value;
  const slug=document.getElementById('slug').value||'your-slug';
  const seoTitle=document.getElementById('seoTitle').value||title||'Your SEO Title';
  const seoDesc=document.getElementById('seoDesc').value||'Meta description...';
  const text=document.getElementById('editor').innerText||'';
  const mins=readTime(text);
  document.getElementById('seo-url-p').textContent=`amdify.io/blog/${slug}`;
  document.getElementById('seo-title-p').textContent=seoTitle;
  document.getElementById('seo-desc-p').textContent=seoDesc;
  document.getElementById('slug-preview').textContent=slug;
  document.getElementById('cv-title').textContent=title||'Title here';
  document.getElementById('cv-excerpt').textContent=excerpt||text.replace(/\n/g,' ').trim().slice(0,140);
  document.getElementById('cv-rt').textContent=`${mins} min read`;
  document.getElementById('cv-date').textContent=new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
  const cc={Technology:['rgba(99,102,241,.1)','#818cf8'],Industry:['rgba(244,63,94,.1)','#fb7185'],Guides:['rgba(16,185,129,.1)','#34d399']};
  const[bg,color]=cc[cat]||cc.Technology;
  const catEl=document.getElementById('cv-cat');catEl.textContent=cat||'Category';catEl.style.background=bg;catEl.style.color=color;
  const st={Technology:'rgba(99,102,241,.5),rgba(99,102,241,.3)',Industry:'rgba(244,63,94,.5),rgba(244,63,94,.3)',Guides:'rgba(16,185,129,.5),rgba(16,185,129,.3)'};
  document.getElementById('card-stripe').style.background=`linear-gradient(90deg,${st[cat]||st.Technology})`;
  document.getElementById('word-count').textContent=`${text.trim().split(/\s+/).filter(Boolean).length} words`;
  document.getElementById('read-time-est').textContent=`~${mins} min read`;
}
document.getElementById('editor').addEventListener('input',updatePreviews);
['title','excerpt','category'].forEach(id=>document.getElementById(id).addEventListener(id==='category'?'change':'input',updatePreviews));

// ── Toolbar ───────────────────────────────────────────
function exec(cmd){document.getElementById('editor').focus();document.execCommand(cmd,false,null);}
window.exec=exec;
function applyBlock(tag){if(!tag)return;document.getElementById('editor').focus();document.execCommand('formatBlock',false,tag);}
window.applyBlock=applyBlock;
function wrapInline(tag){const sel=window.getSelection();if(!sel||sel.isCollapsed)return;const text=sel.toString();document.execCommand('insertHTML',false,`<${tag}>${text}</${tag}>`);}
window.wrapInline=wrapInline;
function clearEditor(){if(!confirm('Clear all content?'))return;document.getElementById('editor').innerHTML='';document.getElementById('paste-banner').className='paste-banner';updatePreviews();}
window.clearEditor=clearEditor;

// ══════════════════════════════════════════════
// ── SMART TABLE ───────────────────────────────
// ══════════════════════════════════════════════
function openSmartTable(){
  document.getElementById('smart-table-input').value='';
  document.getElementById('smart-table-preview').innerHTML='<div style="color:#4b5563;font-size:.8rem;padding:.5rem;">Preview will appear here...</div>';
  document.getElementById('table-detect-info').textContent='Type above to see preview';
  document.getElementById('smart-table-modal').classList.add('show');
  setTimeout(()=>document.getElementById('smart-table-input').focus(),100);
}
function closeSmartTable(){document.getElementById('smart-table-modal').classList.remove('show');}
window.openSmartTable=openSmartTable;
window.closeSmartTable=closeSmartTable;

function detectTableData(rawText) {
  const lines = rawText.split('\n').map(l=>l.trim()).filter(Boolean);
  if (!lines.length) return null;

  // Try | separator first
  if (lines[0].includes('|')) {
    const rows = lines
      .filter(l => !/^[\|\-\s]+$/.test(l)) // skip separator lines
      .map(l => l.split('|').map(c=>c.trim()).filter(Boolean));
    if (rows.length > 0) return rows;
  }

  // Try tab separator
  if (lines[0].includes('\t')) {
    return lines.map(l => l.split('\t').map(c=>c.trim()).filter(Boolean));
  }

  // Try detecting columns by consistent spacing
  // Find the column boundaries from all lines
  const colCounts = lines.map(l => l.split(/\s{2,}/).filter(Boolean).length);
  const mostCommon = colCounts.sort((a,b)=>colCounts.filter(v=>v===b).length-colCounts.filter(v=>v===a).length)[0];

  if (mostCommon >= 2) {
    return lines.map(l => {
      const cols = l.split(/\s{2,}/).filter(Boolean);
      // If fewer columns, try single space split and group
      if (cols.length < 2) {
        const parts = l.split(' ');
        if (parts.length === mostCommon) return parts;
        // Try to split evenly
        const chunkSize = Math.ceil(parts.length / mostCommon);
        const result = [];
        for (let i=0; i<parts.length; i+=chunkSize) result.push(parts.slice(i,i+chunkSize).join(' '));
        return result;
      }
      return cols;
    });
  }

  // Single space fallback - smart split
  return lines.map(l => l.split(/\s+/).filter(Boolean));
}

function previewSmartTable() {
  const raw = document.getElementById('smart-table-input').value;
  const preview = document.getElementById('smart-table-preview');
  const info = document.getElementById('table-detect-info');

  if (!raw.trim()) {
    preview.innerHTML='<div style="color:#4b5563;font-size:.8rem;padding:.5rem;">Preview will appear here...</div>';
    info.textContent='Type above to see preview';
    return;
  }

  const rows = detectTableData(raw);
  if (!rows || rows.length === 0) {
    preview.innerHTML='<div style="color:#f87171;font-size:.8rem;padding:.5rem;">Could not detect columns. Try separating with 2 spaces or |</div>';
    return;
  }

  const cols = Math.max(...rows.map(r=>r.length));
  info.textContent=`✓ Detected ${rows.length} rows × ${cols} columns — click any cell to edit`;

  let html = '<table><thead><tr>';
  (rows[0]||[]).forEach(c => html+=`<th contenteditable="true">${c}</th>`);
  // Fill missing cols
  for(let i=(rows[0]||[]).length;i<cols;i++) html+=`<th contenteditable="true">Column ${i+1}</th>`;
  html += '</tr></thead><tbody>';
  for (let i=1;i<rows.length;i++) {
    html += '<tr>';
    for (let j=0;j<cols;j++) html+=`<td contenteditable="true">${rows[i][j]||''}</td>`;
    html += '</tr>';
  }
  html += '</tbody></table>';
  preview.innerHTML = html;
}

function insertSmartTable() {
  const table = document.getElementById('smart-table-preview').querySelector('table');
  if (!table) { toast('No table to insert. Paste data first.','error'); return; }
  // Remove contenteditable
  table.querySelectorAll('[contenteditable]').forEach(el=>el.removeAttribute('contenteditable'));
  const clone = table.cloneNode(true);
  // Style the table for the editor
  document.getElementById('editor').focus();
  document.execCommand('insertHTML', false, clone.outerHTML + '<p><br></p>');
  closeSmartTable();
  toast('✓ Table inserted!','success');
  updatePreviews();
}

// ── Manual Table ──────────────────────────────────────
function openManualTable(){buildManualTable();document.getElementById('manual-table-modal').classList.add('show');}
function closeManualTable(){document.getElementById('manual-table-modal').classList.remove('show');}
window.openManualTable=openManualTable;window.closeManualTable=closeManualTable;
function buildManualTable(){
  const cols=Math.max(1,Math.min(8,parseInt(document.getElementById('m-cols').value)||3));
  const rows=Math.max(1,Math.min(20,parseInt(document.getElementById('m-rows').value)||3));
  let h='<table><thead><tr>';
  for(let c=0;c<cols;c++) h+=`<th contenteditable="true">Column ${c+1}</th>`;
  h+='</tr></thead><tbody>';
  for(let r=0;r<rows;r++){h+='<tr>';for(let c=0;c<cols;c++) h+=`<td contenteditable="true"></td>`;h+='</tr>';}
  h+='</tbody></table>';
  document.getElementById('manual-table-preview').innerHTML=h;
}
window.buildManualTable=buildManualTable;
function insertManualTable(){
  const tbl=document.getElementById('manual-table-preview').querySelector('table');
  if(!tbl){closeManualTable();return;}
  tbl.querySelectorAll('[contenteditable]').forEach(el=>el.removeAttribute('contenteditable'));
  document.getElementById('editor').focus();
  document.execCommand('insertHTML',false,tbl.outerHTML+'<p><br></p>');
  closeManualTable();
}
window.insertManualTable=insertManualTable;

// ══════════════════════════════════════════════
// ── SMART PASTE HANDLER ───────────────────────
// ══════════════════════════════════════════════
document.getElementById('editor').addEventListener('paste', async function(e) {
  e.preventDefault();
  const clip = e.clipboardData;
  const html  = clip.getData('text/html');
  const plain = clip.getData('text/plain');

  if (html && html.length > 200) {
    // Rich HTML (from Word, Claude, Google Docs) — convert perfectly
    const converted = convertRichHtml(html);
    document.execCommand('insertHTML', false, converted);
    hidePasteBanner();
    toast('✓ Rich content pasted with formatting!','success');
  } else if (plain) {
    // Plain text — insert then show format banner
    const htmlLines = plain.split('\n').map(l =>
      l.trim() ? `<p>${l.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>` : '<p><br></p>'
    ).join('');
    document.execCommand('insertHTML', false, htmlLines);
    showPasteBanner(plain);
  }
  updatePreviews();
});

function convertRichHtml(html) {
  // Handle tables separately
  const tables = [];
  let processed = html.replace(/<table[\s\S]*?<\/table>/gi, tbl => {
    const rows = [...tbl.matchAll(/<tr[\s\S]*?<\/tr>/gi)];
    if (!rows.length) return '';
    let t = '<table>';
    rows.forEach((row,ri) => {
      const cells = [...row[0].matchAll(/<t[hd][^>]*>([\s\S]*?)<\/t[hd]>/gi)]
        .map(c=>c[1].replace(/<[^>]+>/g,'').replace(/&amp;/g,'&').replace(/&nbsp;/g,' ').trim());
      if (ri===0) t+=`<thead><tr>${cells.map(c=>`<th>${c}</th>`).join('')}</tr></thead><tbody>`;
      else t+=`<tr>${cells.map(c=>`<td>${c}</td>`).join('')}</tr>`;
    });
    t+='</tbody></table>';
    const ph=`__TBL${tables.length}__`;tables.push(t);return ph;
  });

  processed = processed
    .replace(/<h1[^>]*>([\s\S]*?)<\/h1>/gi,'<h2>$1</h2>')
    .replace(/<h2[^>]*>([\s\S]*?)<\/h2>/gi,'<h2>$1</h2>')
    .replace(/<h3[^>]*>([\s\S]*?)<\/h3>/gi,'<h3>$1</h3>')
    .replace(/<h4[^>]*>([\s\S]*?)<\/h4>/gi,'<h4>$1</h4>')
    .replace(/<h5[^>]*>([\s\S]*?)<\/h5>/gi,'<h4>$1</h4>')
    .replace(/<(strong|b)[^>]*>([\s\S]*?)<\/(strong|b)>/gi,'<strong>$2</strong>')
    .replace(/<(em|i)[^>]*>([\s\S]*?)<\/(em|i)>/gi,'<em>$2</em>')
    .replace(/<li[^>]*>([\s\S]*?)<\/li>/gi,'<li>$1</li>')
    .replace(/<br\s*\/?>/gi,'<br>')
    .replace(/<p[^>]*>([\s\S]*?)<\/p>/gi,'<p>$1</p>')
    .replace(/<[^>]+>/g, m => /^<(h[1-6]|p|ul|ol|li|br|strong|em|table|thead|tbody|tr|th|td|blockquote|hr)\b/i.test(m) || /^<\/(h[1-6]|p|ul|ol|li|strong|em|table|thead|tbody|tr|th|td|blockquote)\b/i.test(m) ? m : '')
    .replace(/&nbsp;/g,' ');

  tables.forEach((t,i)=>{ processed=processed.replace(`__TBL${i}__`,t); });
  return processed;
}

