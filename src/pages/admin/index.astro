async function handleFile(file){
  const ext=file.name.split('.').pop().toLowerCase();
  if(!['docx','pdf','txt'].includes(ext)){toast('Only .docx .pdf .txt','error');return;}
  const badge=document.getElementById('file-badge');
  badge.textContent=ext.toUpperCase();badge.className=`file-badge ${ext}`;
  document.getElementById('file-name').textContent=file.name;
  document.getElementById('file-size').textContent=`${(file.size/1024).toFixed(1)} KB`;
  document.getElementById('file-status').className='file-status show';
  uz.classList.add('has-file');
  setProgress(true,'Reading file...',15);
  try{
    let payload={};
    if(ext==='docx'){
      setProgress(true,'Extracting Word document...',30);
      const buf=await file.arrayBuffer();
      const result=await mammoth.convertToHtml({arrayBuffer:buf});
      payload={content:result.value,mode:'html'};
      document.getElementById('file-size').textContent+=` — ${result.value.replace(/<[^>]+>/g,'').split(/\s+/).length} words`;
    } else if(ext==='txt'){
      const text=await file.text();
      payload={content:text,mode:'text'};
      document.getElementById('file-size').textContent+=` — ${text.split(/\s+/).length} words`;
    } else {
      setProgress(true,'Reading PDF pages...',20);
      const text=await extractPdfWithPositions(file);
      payload={content:text,mode:'text'};
      document.getElementById('file-size').textContent+=` — ${text.split(/\s+/).length} words`;
    }
    setProgress(true,'Formatting content...',60);
    const res=await fetch('/api/format',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const data=await res.json();
    if(!res.ok||data.error){toast(data.error||'Format error.','error');setProgress(false);return;}
    if(data.title){document.getElementById('title').value=data.title;updateCount('title','tc',120);syncSlug();}
    if(data.excerpt){document.getElementById('excerpt').value=data.excerpt;updateCount('excerpt','ec',200);}
    if(data.category) document.getElementById('category').value=data.category;
    if(data.seoTitle){document.getElementById('seoTitle').value=data.seoTitle;updateCount('seoTitle','stc',65);}
    if(data.seoDescription){document.getElementById('seoDesc').value=data.seoDescription;updateCount('seoDesc','sdc',160);}
    if(data.slug){document.getElementById('slug').value=data.slug;slugManual=true;}
    if(data.content) document.getElementById('editor').innerHTML=markdownToHtml(data.content);
    setProgress(false);hidePasteBanner();
    document.getElementById('file-size').textContent+=' ✓';
    updatePreviews();
    toast('✓ File imported with headings and tables!','success');
  }catch(e){toast('Error: '+e.message,'error');setProgress(false);}
}

async function extractPdfWithPositions(file){
  const buf=await file.arrayBuffer();
  const pdf=await pdfjsLib.getDocument({data:buf}).promise;
  const allLines=[];

  for(let p=1;p<=pdf.numPages;p++){
    setProgress(true,`Reading PDF page ${p}/${pdf.numPages}...`,20+(p/pdf.numPages)*35);
    const page=await pdf.getPage(p);
    const content=await page.getTextContent();

    // Group items by rounded Y position
    const yMap=new Map();
    for(const item of content.items){
      const y=Math.round(item.transform[5]/3)*3; // round to nearest 3px
      const x=item.transform[4];
      const fontSize=Math.round(Math.abs(item.transform[0]));
      if(!yMap.has(y)) yMap.set(y,{items:[],fontSize:0});
      const row=yMap.get(y);
      row.items.push({x,text:item.str,fontSize});
      row.fontSize=Math.max(row.fontSize,fontSize);
    }

    // Sort rows top→bottom
    const sortedRows=[...yMap.entries()].sort((a,b)=>b[0]-a[0]);

    // Find body font size (most common)
    const sizes=sortedRows.map(([,r])=>r.fontSize).filter(s=>s>0);
    const sizeCount={};sizes.forEach(s=>{sizeCount[s]=(sizeCount[s]||0)+1;});
    const bodySize=parseInt(Object.entries(sizeCount).sort((a,b)=>b[1]-a[1])[0]?.[0]||'11');

    for(const[,row] of sortedRows){
      // Sort items left→right within row
      row.items.sort((a,b)=>a.x-b.x);
      const lineText=row.items.map(i=>i.str).join(' ').trim();
      if(!lineText) continue;

      // Detect headings by font size
      const isHeading=row.fontSize>bodySize+2&&lineText.length<100;
      const isLargeHeading=row.fontSize>bodySize+5&&lineText.length<80;

      if(isLargeHeading) allLines.push(`## ${lineText}`);
      else if(isHeading)  allLines.push(`### ${lineText}`);
      else                allLines.push(lineText);
    }
    allLines.push('');
  }

  // Post-process: detect tables from consecutive lines with multiple x-separated columns
  return postProcessPdfLines(allLines);
}

function postProcessPdfLines(lines){
  const out=[];
  let tableRows=[];
  let tableCols=0;

  function flushTable(){
    if(tableRows.length>=2){
      out.push('');
      out.push('| '+tableRows[0].join(' | ')+' |');
      out.push('| '+tableRows[0].map(()=>'---').join(' | ')+' |');
      for(let i=1;i<tableRows.length;i++) out.push('| '+tableRows[i].join(' | ')+' |');
      out.push('');
    } else {
      tableRows.forEach(r=>out.push(r.join(' ')));
    }
    tableRows=[];tableCols=0;
  }

  for(const line of lines){
    if(!line.trim()){if(tableRows.length)flushTable();out.push('');continue;}
    if(line.startsWith('##')||line.startsWith('###')){if(tableRows.length)flushTable();out.push(line);continue;}

    // Detect if line looks like a table row (2+ spaced columns)
    const cols=line.split(/\s{2,}/).filter(Boolean);
    if(cols.length>=2&&cols.every(c=>c.length<40)){
      if(!tableRows.length||cols.length===tableCols){
        tableRows.push(cols);tableCols=cols.length;
        continue;
      } else {
        flushTable();tableRows.push(cols);tableCols=cols.length;continue;
      }
    }
    if(tableRows.length) flushTable();

    // Bullet detection
    if(/^[•·●]\s/.test(line)) out.push('- '+line.replace(/^[•·●]\s*/,''));
    else out.push(line);
  }
  if(tableRows.length) flushTable();
  return out.join('\n').replace(/\n{3,}/g,'\n\n').trim();
}

